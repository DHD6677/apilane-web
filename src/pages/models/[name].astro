---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getModels, fmtUsd, fmtContext, type ModelInfo } from '../../data/models';

export async function getStaticPaths() {
  const models = await getModels();
  return models.map((m) => ({
    params: { name: m.slug },
    props: { model: m }
  }));
}

interface Props { model: ModelInfo }
const { model } = Astro.props;
const baseUrl = 'https://api.apilane.one/v1';
const title = `${model.name} API - ${fmtUsd(model.usdPerCall)} | apilane`;
const description = `${model.name} from ${model.vendor}. ${model.blurb} Flat per-call pricing, OpenAI-compatible endpoint.`;

const curlCode = `curl ${baseUrl}/chat/completions \\
  -H "Authorization: Bearer sk-apilane-..." \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "${model.name}",
    "messages": [{"role": "user", "content": "Hello"}]
  }'`;

const pythonCode = `from openai import OpenAI

client = OpenAI(
    api_key="sk-apilane-...",
    base_url="${baseUrl}",
)

resp = client.chat.completions.create(
    model="${model.name}",
    messages=[{"role": "user", "content": "Hello"}],
)
print(resp.choices[0].message.content)`;
---

<Layout title={title} description={description}>
  <Nav />
  <main class="flex-1">
    <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12">
      <a href="/models" class="inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-zinc-300 transition-colors mb-6">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        All models
      </a>

      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="font-mono text-3xl sm:text-4xl font-bold tracking-tight text-zinc-50">{model.name}</h1>
          <p class="mt-1 text-zinc-500">{model.vendor}</p>
        </div>
        <div class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-2 text-right">
          <div class="text-2xl font-bold text-emerald-400">{fmtUsd(model.usdPerCall)}</div>
          <div class="text-xs text-zinc-500">flat, per call</div>
        </div>
      </div>

      <p class="mt-6 text-zinc-300 leading-relaxed">{model.blurb}</p>

      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="rounded-lg border border-zinc-800 bg-zinc-900/40 p-4">
          <div class="text-xs text-zinc-500">Context</div>
          <div class="mt-1 font-semibold text-zinc-200">{fmtContext(model.contextLength)} tokens</div>
        </div>
        <div class="rounded-lg border border-zinc-800 bg-zinc-900/40 p-4">
          <div class="text-xs text-zinc-500">Pricing</div>
          <div class="mt-1 font-semibold text-zinc-200">per call</div>
        </div>
        <div class="rounded-lg border border-zinc-800 bg-zinc-900/40 p-4">
          <div class="text-xs text-zinc-500">Protocols</div>
          <div class="mt-1 font-semibold text-zinc-200">{model.formats.join(' / ')}</div>
        </div>
        <div class="rounded-lg border border-zinc-800 bg-zinc-900/40 p-4">
          <div class="text-xs text-zinc-500">call_price</div>
          <div class="mt-1 font-semibold text-zinc-200">{model.call_price}</div>
        </div>
      </div>

      <div class="mt-10">
        <h2 class="text-lg font-semibold text-zinc-100 mb-4">Quick start</h2>
        <div class="rounded-xl border border-zinc-800 bg-zinc-950 overflow-hidden">
          <div class="flex gap-1 border-b border-zinc-800 px-4">
            <button data-tab="python" class="dt-tab px-4 py-3 text-sm font-medium text-zinc-100 border-b-2 border-emerald-400">Python</button>
            <button data-tab="curl" class="dt-tab px-4 py-3 text-sm font-medium text-zinc-500 border-b-2 border-transparent hover:text-zinc-300">curl</button>
          </div>
          <div data-code="python" class="p-5 overflow-x-auto">
            <pre class="text-sm font-mono leading-relaxed text-zinc-300"><code set:html={pythonCode}></code></pre>
          </div>
          <div data-code="curl" class="hidden p-5 overflow-x-auto">
            <pre class="text-sm font-mono leading-relaxed text-zinc-300"><code set:html={curlCode}></code></pre>
          </div>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="https://api.apilane.one/register" class="inline-flex items-center justify-center rounded-md bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-emerald-400 transition-colors">Get API key</a>
        <a href="/models" class="inline-flex items-center justify-center rounded-md border border-zinc-700 bg-zinc-900 px-5 py-2.5 text-sm font-semibold text-zinc-100 hover:border-zinc-600 hover:bg-zinc-800 transition-colors">Compare models</a>
      </div>
    </section>
  </main>
  <Footer />
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: model.name,
  applicationCategory: 'DeveloperApplication',
  description: model.blurb,
  offers: {
    '@type': 'Offer',
    price: model.usdPerCall.toFixed(5),
    priceCurrency: 'USD',
    description: 'Per call'
  }
})} />

<script>
  const tabs = document.querySelectorAll('.dt-tab');
  const panels = document.querySelectorAll('[data-code]');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('text-zinc-100', active);
        t.classList.toggle('text-zinc-500', !active);
        t.classList.toggle('border-emerald-400', active);
        t.classList.toggle('border-transparent', !active);
      });
      panels.forEach((p) => {
        p.classList.toggle('hidden', p.getAttribute('data-code') !== target);
      });
    });
  });
</script>
</Layout>
