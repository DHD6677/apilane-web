---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getModels, fmtUsd, fmtContext, type ModelInfo } from '../../data/models';

const models: ModelInfo[] = await getModels();
const title = 'Models - apilane';
const description = 'All tested AI models available on apilane with flat per-call pricing.';
---

<Layout title={title} description={description}>
  <Nav />
  <main class="flex-1">
    <section class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
      <div class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-50">Models</h1>
        <p class="mt-3 text-zinc-400 max-w-2xl">
          Every model below is one we have actually tested. Flat price per call - no token math. If an upstream provider becomes unstable, we swap it out.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {models.map((m) => (
          <a href={`/models/${m.slug}`} class="group rounded-xl border border-zinc-800 bg-zinc-900/40 p-6 hover:border-emerald-500/50 hover:bg-zinc-900/70 transition-colors">
            <div class="flex items-start justify-between">
              <div>
                <h2 class="font-mono text-zinc-100 font-semibold group-hover:text-emerald-400 transition-colors">{m.name}</h2>
                <p class="mt-0.5 text-xs text-zinc-500">{m.vendor}</p>
              </div>
              <span class="text-sm font-semibold text-emerald-400">{fmtUsd(m.usdPerCall)}</span>
            </div>
            <p class="mt-3 text-sm text-zinc-400 leading-relaxed line-clamp-2">{m.blurb}</p>
            <div class="mt-4 flex items-center gap-3 text-xs text-zinc-500">
              <span>ctx {fmtContext(m.contextLength)}</span>
              <span>·</span>
              <span>{m.formats.join(' / ')}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
