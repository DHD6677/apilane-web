---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { getModels, fmtUsd, fmtContext, type ModelInfo } from '../../../data/models';
import { locales, useTranslations, localePath, type Locale } from '../../../i18n/utils';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of locales) {
    const models = await getModels(locale);
    paths.push({ params: { locale }, props: { models, locale } });
  }
  return paths;
}

interface Props { models: ModelInfo[]; locale: Locale }
const { models, locale } = Astro.props;
const t = useTranslations(locale);
const title = t('models.page_title');
const description = t('models.description');
---

<Layout title={title} description={description} locale={locale} path="models">
  <Nav locale={locale} path="models" />
  <main class="flex-1">
    <section class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
      <div class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-50">{t('models.h1')}</h1>
        <p class="mt-3 text-zinc-400 max-w-2xl">
          {t('models.intro')}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {models.map((m) => (
          <a href={localePath(locale, `models/${m.slug}`)} class="group rounded-xl border border-zinc-800 bg-zinc-900/40 p-6 hover:border-emerald-500/50 hover:bg-zinc-900/70 transition-colors">
            <div class="flex items-start justify-between">
              <div>
                <h2 class="font-mono text-zinc-100 font-semibold group-hover:text-emerald-400 transition-colors">{m.name}</h2>
                <p class="mt-0.5 text-xs text-zinc-500">{m.vendor}</p>
              </div>
              <span class="text-sm font-semibold text-emerald-400">{fmtUsd(m.usdPerCall)}</span>
            </div>
            <p class="mt-3 text-sm text-zinc-400 leading-relaxed line-clamp-2">{m.blurb}</p>
            <div class="mt-4 flex items-center gap-3 text-xs text-zinc-500">
              <span>{t('models.ctx_label')} {fmtContext(m.contextLength)}</span>
              <span>·</span>
              <span>{m.formats.join(' / ')}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
