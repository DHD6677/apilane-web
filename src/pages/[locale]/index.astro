---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Stats from '../../components/Stats.astro';
import Pricing from '../../components/Pricing.astro';
import Features from '../../components/Features.astro';
import CodeExample from '../../components/CodeExample.astro';
import Trust from '../../components/Trust.astro';
import FAQ from '../../components/FAQ.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import Footer from '../../components/Footer.astro';
import { locales, useTranslations, type Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const title = locale === 'zh' ? 'apilane - 高性价比 AI API' : 'apilane - Affordable AI API';
const description = t('hero.subtitle');
---

<Layout title={title} description={description} locale={locale} path="">
  <Nav locale={locale} />
  <main class="flex-1">
    <Hero locale={locale} />
    <Stats locale={locale} />
    <Pricing locale={locale} />
    <Features locale={locale} />
    <CodeExample locale={locale} />
    <Trust locale={locale} />
    <FAQ locale={locale} />
    <FinalCTA locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
