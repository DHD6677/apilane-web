---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { locales, useTranslations, localePath, type Locale } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

const all = await getCollection('blog');
const posts = all
  .filter((p) => p.data.locale === locale)
  .sort((a, b) => (a.data.pubDate < b.data.pubDate ? 1 : -1));

const title = t('blog.page_title');
const description = t('blog.description');
---

<Layout title={title} description={description} locale={locale} path="blog">
  <Nav locale={locale} path="blog" />
  <main class="flex-1">
    <section class="mx-auto max-w-4xl px-4 sm:px-6 py-16">
      <div class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-50">{t('blog.h1')}</h1>
        <p class="mt-3 text-zinc-400 max-w-2xl">{t('blog.intro')}</p>
      </div>

      <div class="space-y-4">
        {posts.map((post) => {
          const dateStr = post.data.pubDate.toLocaleDateString(locale === 'zh' ? 'zh-CN' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' });
          const minRead = `${post.data.readingMinutes} ${t('blog.min_read')}`;
          const updated = t('blog.updated_label').replace('{date}', dateStr);
          return (
          <a href={localePath(locale, `blog/${post.data.slug}`)} class="group block rounded-xl border border-zinc-800 bg-zinc-900/40 p-6 hover:border-emerald-500/50 hover:bg-zinc-900/70 transition-colors">
            <div class="flex items-center gap-3 text-xs text-zinc-500">
              <span class="text-emerald-400">{post.data.category}</span>
              <span>·</span>
              <span>{minRead}</span>
            </div>
            <h2 class="mt-2 text-xl font-semibold text-zinc-100 group-hover:text-emerald-400 transition-colors">{post.data.title}</h2>
            <p class="mt-2 text-sm text-zinc-400 leading-relaxed line-clamp-2">{post.data.description}</p>
            <div class="mt-3 text-xs text-zinc-600">{updated}</div>
          </a>
          );
        })}
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
