---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { locales, useTranslations, type Locale } from '../../../i18n/utils';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

const title = locale === 'zh' ? '快速开始 - apilane' : 'Quick start - apilane';
const description = locale === 'zh'
  ? '两步接入 apilane：注册账号、创建 API Key、修改 base_url。兼容 OpenAI SDK。'
  : 'Get started with apilane in two steps: sign up, create an API key, change base_url. OpenAI SDK compatible.';
const path = 'docs/quickstart';
const ogImage = '/images/pages/quickstart-hero.jpg';

const baseUrl = 'https://api.apilane.one/v1';

const pythonCode = `from openai import OpenAI

client = OpenAI(
    api_key="sk-apilane-...",
    base_url="${baseUrl}",
)

resp = client.chat.completions.create(
    model="MiniMax-M3",
    messages=[{"role": "user", "content": "Say hi in one word."}],
)
print(resp.choices[0].message.content)`;

const nodeCode = `import OpenAI from 'openai';

const client = new OpenAI({
  apiKey: 'sk-apilane-...',
  baseURL: '${baseUrl}',
});

const resp = await client.chat.completions.create({
  model: 'MiniMax-M3',
  messages: [{ role: 'user', content: 'Say hi in one word.' }],
});

console.log(resp.choices[0].message.content);`;

const curlCode = `curl ${baseUrl}/chat/completions \\
  -H "Authorization: Bearer sk-apilane-..." \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "MiniMax-M3",
    "messages": [{"role": "user", "content": "Say hi in one word."}]
  }'`;

const steps = locale === 'zh' ? [
  { n: '01', title: '注册账号', desc: '访问 api.apilane.one/register，用邮箱注册并登录控制台。' },
  { n: '02', title: '充值', desc: '进入「充值」页面，选择 $2 / $5 / $10 / $20 档位，用 USDT（TRC20/BSC）完成支付。' },
  { n: '03', title: '创建 API Key', desc: '在「API Keys」页面点击「添加新的令牌」，复制生成的 sk-apilane-... Key。' },
  { n: '04', title: '改 base_url', desc: '把你代码里的 base_url 改成 https://api.apilane.one/v1，模型名从我们支持的列表里选一个。' }
] : [
  { n: '01', title: 'Sign up', desc: 'Go to api.apilane.one/register, create an account, and log in to the console.' },
  { n: '02', title: 'Deposit', desc: 'Visit the top-up page, pick a $2 / $5 / $10 / $20 tier, and pay with USDT (TRC20/BSC).' },
  { n: '03', title: 'Create an API key', desc: 'On the API Keys page, click "Add new token" and copy the generated sk-apilane-... key.' },
  { n: '04', title: 'Change base_url', desc: 'Replace the base_url in your code with https://api.apilane.one/v1 and pick a supported model name.' }
];
---

<Layout title={title} description={description} locale={locale} path={path} ogImage={ogImage}>
  <Nav locale={locale} />
  <main class="flex-1">
    <section class="border-b border-zinc-800/80">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20">
        <div class="grid gap-10 lg:grid-cols-2 items-center">
          <div>
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-zinc-50">{locale === 'zh' ? '快速开始' : 'Quick start'}</h1>
            <p class="mt-5 text-lg text-zinc-400">
              {locale === 'zh'
                ? '如果你已经在用 OpenAI SDK，只需改两个参数：base_url 和 api_key。'
                : 'If you are already using the OpenAI SDK, change only two parameters: base_url and api_key.'}
            </p>
          </div>
          <div class="rounded-2xl border border-zinc-800 overflow-hidden">
            <img src={ogImage} alt={title} class="w-full h-64 object-cover" loading="eager" />
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {steps.map((s) => (
            <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-6">
              <span class="text-2xl font-bold text-emerald-400">{s.n}</span>
              <h3 class="mt-3 font-semibold text-zinc-100">{s.title}</h3>
              <p class="mt-2 text-sm text-zinc-400">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-y border-zinc-800/80 bg-zinc-900/30">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-zinc-50 mb-8">{locale === 'zh' ? '代码示例' : 'Code examples'}</h2>
        <div class="mx-auto max-w-3xl rounded-xl border border-zinc-800 bg-zinc-950 overflow-hidden">
          <div class="flex items-center justify-between border-b border-zinc-800 px-4 overflow-x-auto">
            <div class="flex gap-1 min-w-fit">
              <button data-tab="python" class="code-tab px-4 py-3 text-sm font-medium text-zinc-100 border-b-2 border-emerald-400 whitespace-nowrap">Python</button>
              <button data-tab="node" class="code-tab px-4 py-3 text-sm font-medium text-zinc-500 border-b-2 border-transparent hover:text-zinc-300 whitespace-nowrap">Node.js</button>
              <button data-tab="curl" class="code-tab px-4 py-3 text-sm font-medium text-zinc-500 border-b-2 border-transparent hover:text-zinc-300 whitespace-nowrap">curl</button>
            </div>
            <span class="text-xs text-zinc-600 hidden sm:inline">base_url: {baseUrl}</span>
          </div>

          <div data-code="python" class="p-5 overflow-x-auto">
            <pre class="text-sm font-mono leading-relaxed text-zinc-300"><code set:html={pythonCode}></code></pre>
          </div>
          <div data-code="node" class="hidden p-5 overflow-x-auto">
            <pre class="text-sm font-mono leading-relaxed text-zinc-300"><code set:html={nodeCode}></code></pre>
          </div>
          <div data-code="curl" class="hidden p-5 overflow-x-auto">
            <pre class="text-sm font-mono leading-relaxed text-zinc-300"><code set:html={curlCode}></code></pre>
          </div>
        </div>
        <p class="mt-4 text-sm text-zinc-500">
          {locale === 'zh'
            ? '注意：示例里的 model 是 MiniMax-M3。你可以在「模型」页看到所有实测可用模型及其价格。'
            : 'Note: the example uses the MiniMax-M3 model. Visit the Models page for all tested models and prices.'}
        </p>
      </div>
    </section>

    <section>
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-zinc-50 mb-6">{locale === 'zh' ? '下一步' : 'What is next'}</h2>
        <div class="grid gap-4 sm:grid-cols-2 max-w-3xl">
          <a href={`/${locale}/models`} class="group rounded-xl border border-zinc-800 bg-zinc-900/30 p-6 hover:border-zinc-700 transition-colors">
            <h3 class="font-semibold text-zinc-100 group-hover:text-emerald-400 transition-colors">{locale === 'zh' ? '浏览模型目录' : 'Browse models'}</h3>
            <p class="mt-2 text-sm text-zinc-400">{locale === 'zh' ? '查看实测模型、上下文长度、按次价格和协议支持。' : 'See tested models, context lengths, per-call prices, and supported protocols.'}</p>
          </a>
          <a href={`/${locale}/pricing`} class="group rounded-xl border border-zinc-800 bg-zinc-900/30 p-6 hover:border-zinc-700 transition-colors">
            <h3 class="font-semibold text-zinc-100 group-hover:text-emerald-400 transition-colors">{locale === 'zh' ? '查看完整定价' : 'View full pricing'}</h3>
            <p class="mt-2 text-sm text-zinc-400">{locale === 'zh' ? '了解 quota 换算、充值档位和失败计费规则。' : 'Learn quota conversion, deposit tiers, and failed-call billing.'}</p>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>

<script>
  const tabs = document.querySelectorAll('.code-tab');
  const panels = document.querySelectorAll('[data-code]');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('text-zinc-100', active);
        t.classList.toggle('text-zinc-500', !active);
        t.classList.toggle('border-emerald-400', active);
        t.classList.toggle('border-transparent', !active);
      });
      panels.forEach((p) => {
        p.classList.toggle('hidden', p.getAttribute('data-code') !== target);
      });
    });
  });
</script>
