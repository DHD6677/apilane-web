---
import { useTranslations, type Locale } from '../i18n/utils';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const stats = [
  { value: '5', label: t('stats.tested_models') },
  { value: '1/10–1/60', label: t('stats.official_price') },
  { value: '$2', label: t('stats.min_deposit') },
  { value: '0', label: t('stats.prompt_storage') }
];
---

<section class="border-y border-zinc-800/80 bg-zinc-900/30">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <dl class="grid grid-cols-2 sm:grid-cols-4 divide-x divide-zinc-800/80">
      {stats.map((s) => (
        <div class="px-4 py-8 text-center">
          <dt class="text-2xl sm:text-3xl font-bold text-emerald-400">{s.value}</dt>
          <dd class="mt-1 text-xs sm:text-sm text-zinc-500">{s.label}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
