---
import { useTranslations, localePath, type Locale } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
  path?: string;
  showAnchors?: boolean;
}

const { locale, path = '', showAnchors = false } = Astro.props;
const t = useTranslations(locale);
const appUrl = 'https://api.apilane.one/login';
const dashboardUrl = 'https://api.apilane.one/dashboard';
const clean = path.replace(/^\/+/, '').replace(/\/+$/, '');
const modelsHref = localePath(locale, 'models');
const blogHref = localePath(locale, 'blog');
const pricingHref = localePath(locale, 'pricing');
const signinLabel = t('nav.signin');
const dashboardLabel = t('nav.dashboard');
---

<nav class="sticky top-0 z-50 border-b border-zinc-800/80 bg-zinc-950/80 backdrop-blur">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex h-16 items-center justify-between">
      <a href={localePath(locale)} class="flex items-center gap-2 text-zinc-100 font-semibold tracking-tight">
        <Logo size={28} />
        <span class="text-lg">apilane</span>
      </a>
      <div class="flex items-center gap-3 sm:gap-6">
        <a href={modelsHref} class="hidden sm:inline text-sm text-zinc-400 hover:text-zinc-100 transition-colors">{t('nav.models')}</a>
        <a href={pricingHref} class="hidden sm:inline text-sm text-zinc-400 hover:text-zinc-100 transition-colors">{t('nav.pricing')}</a>
        <a href={blogHref} class="hidden sm:inline text-sm text-zinc-400 hover:text-zinc-100 transition-colors">{t('nav.blog')}</a>
        {showAnchors && (
          <>
            <a href="#pricing" class="hidden sm:inline text-sm text-zinc-400 hover:text-zinc-100 transition-colors">{t('nav.pricing')}</a>
            <a href="#features" class="hidden sm:inline text-sm text-zinc-400 hover:text-zinc-100 transition-colors">{t('nav.features')}</a>
            <a href="#faq" class="hidden sm:inline text-sm text-zinc-400 hover:text-zinc-100 transition-colors">{t('nav.faq')}</a>
          </>
        )}
        <LanguageSwitcher locale={locale} path={clean} />
        <a
          id="nav-auth-btn"
          href={appUrl}
          class="inline-flex items-center rounded-md border border-zinc-700 bg-zinc-900 px-3 py-1.5 text-sm font-medium text-zinc-100 hover:border-zinc-600 hover:bg-zinc-800 transition-colors"
        >
          {signinLabel}
        </a>
      </div>
    </div>
  </div>
</nav>

<script is:inline define:vars={{ dashboardUrl, dashboardLabel }}>
  (async () => {
    try {
      const res = await fetch('https://api.apilane.one/api/user/self', {
        credentials: 'include',
      });
      if (res.ok) {
        const data = await res.json();
        if (data.success && data.data) {
          const btn = document.getElementById('nav-auth-btn');
          if (btn) {
            btn.href = dashboardUrl;
            btn.textContent = dashboardLabel;
          }
        }
      }
    } catch (e) {}
  })();
</script>
