---
const appUrl = 'https://app.apilane.one';
---

<nav class="sticky top-0 z-50 border-b border-zinc-800/80 bg-zinc-950/80 backdrop-blur">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-zinc-100 font-semibold tracking-tight">
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-emerald-500 text-zinc-950 font-bold text-sm">a</span>
        <span class="text-lg">apilane</span>
      </a>
      <div class="flex items-center gap-3 sm:gap-6">
        <a href="#pricing" class="hidden sm:inline text-sm text-zinc-400 hover:text-zinc-100 transition-colors">Pricing</a>
        <a href="#features" class="hidden sm:inline text-sm text-zinc-400 hover:text-zinc-100 transition-colors">Features</a>
        <a href="#faq" class="hidden sm:inline text-sm text-zinc-400 hover:text-zinc-100 transition-colors">FAQ</a>
        <a href={appUrl} class="inline-flex items-center rounded-md border border-zinc-700 bg-zinc-900 px-3 py-1.5 text-sm font-medium text-zinc-100 hover:border-zinc-600 hover:bg-zinc-800 transition-colors">
          Sign in
        </a>
      </div>
    </div>
  </div>
</nav>