---
const points = [
  {
    title: 'No prompt storage',
    desc: 'Requests are forwarded to upstream and discarded immediately. We never store your prompt content.'
  },
  {
    title: 'API keys stay in memory',
    desc: 'Your key is loaded for routing and never written to disk or logs. Rotate anytime from the console.'
  },
  {
    title: 'Self-hosted BTCPay',
    desc: 'Crypto payments run on our own BTCPay Server. No third-party processor ever sees your transaction.'
  },
  {
    title: 'Responses passed through unmodified',
    desc: 'We do not rewrite, filter, or inspect model responses. What the model returns is what you get.'
  },
  {
    title: 'Anonymous access available',
    desc: 'A Tor .onion endpoint is available for developers who need anonymous API access.'
  }
];
---

<section id="trust" class="scroll-mt-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-50">Trust &amp; security</h2>
      <p class="mt-3 text-zinc-400">Cheap doesn't have to mean shady. Here's exactly what we do and don't do with your data.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {points.map((p) => (
        <div class="flex gap-4 rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
          <div class="mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-emerald-500/10 text-emerald-400">
            <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-7.5 7.5a1 1 0 01-1.4 0L3.3 9.7a1 1 0 011.4-1.4l3.1 3.1 6.8-6.8a1 1 0 011.4 0z" clip-rule="evenodd"/></svg>
          </div>
          <div>
            <h3 class="text-zinc-100 font-semibold">{p.title}</h3>
            <p class="mt-1 text-sm text-zinc-400 leading-relaxed">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>