---
import { useTranslations, localePath, type Locale } from '../i18n/utils';
import Logo from './Logo.astro';

interface Props { locale: Locale; showAnchors?: boolean }
const { locale, showAnchors = false } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
const modelsHref = localePath(locale, 'models');
const blogHref = localePath(locale, 'blog');
const pricingHref = localePath(locale, 'pricing');
const docsHref = localePath(locale, 'docs/quickstart');
const securityHref = localePath(locale, 'security');
---

<footer class="border-t border-zinc-800/80 bg-zinc-950">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <a href={localePath(locale)} class="flex items-center gap-2 text-zinc-100 font-semibold">
        <Logo size={24} />
        apilane
      </a>
      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-zinc-400">
        <a href={modelsHref} class="hover:text-zinc-100 transition-colors">{t('nav.models')}</a>
        <a href={pricingHref} class="hover:text-zinc-100 transition-colors">{t('nav.pricing')}</a>
        <a href={blogHref} class="hover:text-zinc-100 transition-colors">{t('nav.blog')}</a>
        <a href={docsHref} class="hover:text-zinc-100 transition-colors">{t('nav.docs')}</a>
        <a href={securityHref} class="hover:text-zinc-100 transition-colors">{t('nav.security')}</a>
        <a href="https://api.apilane.one" class="hover:text-zinc-100 transition-colors">{t('footer.console')}</a>
        <a href="https://stats.uptimerobot.com/eHPmpHnXoV" class="hover:text-zinc-100 transition-colors">{t('footer.status')}</a>
        <a href="https://github.com/apilane" class="hover:text-zinc-100 transition-colors">GitHub</a>
      </nav>
    </div>
    <p class="mt-8 text-center text-xs text-zinc-600">© {year} apilane. {t('footer.copyright')}</p>
  </div>
</footer>
